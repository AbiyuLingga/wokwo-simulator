{
  "name": "ZMPT101B Voltage Sensor",
  "author": "Codex",
  "pins": [
    "AC_L",
    "AC_N",
    "VCC",
    "OUT",
    "GND"
  ],
  "controls": [
    {
      "id": "voltageRms",
      "label": "PLN RMS voltage",
      "type": "range",
