      "max": 250,
      "step": 1
    },
    {
      "id": "frequency",
      "label": "Frequency",
      "type": "range",
      "min": 45,
      "max": 65,
      "step": 1
    },
    {
      "id": "sensorRmsAt220",
      "label": "Sensor RMS at 220V",
      "type": "range",
      "min": 0.2,
      "max": 1.5,
      "step": 0.01
    }
  ]
}
